@startuml importarGrados-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":Grados Abierto" as GradosAbierto

package importarGrados as "importarGrados()" {

    rectangle #629EF9 ImportarGradosView
    rectangle #b5bd68 GradoController
    rectangle #F2AC4E GradoRepository
    rectangle #F2AC4E Grado
}

GradosAbierto -r-> ImportarGradosView : importarGrados()

ImportarGradosView -d-> GradoController : importar(archivo) : ImportResult

ImportarGradosView -d-> GradoController : obtenerFormatoRequerido()

GradoController -r-> GradoRepository : guardarLote(grados)
GradoRepository -- Grado

ImportarGradosView ..> GradosAbierto : mostrarResultado(importResult)
ImportarGradosView ..> GradosAbierto : cancelarImportacion()

@enduml