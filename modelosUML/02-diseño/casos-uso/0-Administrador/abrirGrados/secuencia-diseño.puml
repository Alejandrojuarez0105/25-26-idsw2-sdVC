@startuml secuencia-diseño
skinparam shadowing false

actor Administrador
participant "GradosListView\n(React)" as UI <<Component>>
participant "useGrados\n(Hook)" as Hook <<Hook>>
participant "GradosService\n(Axios)" as FService <<Service>>
participant "GradosController\n(NestJS)" as Controller <<Controller>>
participant "GradosService\n(NestJS)" as BService <<Service>>
database "PostgreSQL" as DB

Administrador -> UI : Accede a la gestión de grados
UI -> Hook : fetchGrados(query)
Hook -> FService : getGrados(query)
FService -> Controller : GET /grados?search=...&page=...
Controller -> BService : findAll(query)
BService -> DB : SELECT * FROM "Grado" WHERE ... LIMIT ... OFFSET ...
DB --> BService : Listado de Grados + Total
BService --> Controller : PaginatedGradosDTO
Controller --> FService : JSON Response
FService --> Hook : PaginatedGradosDTO
Hook --> UI : Actualiza estado (grados)
UI --> Administrador : Muestra tabla de grados
@enduml
