@startuml secuencia-diseño
skinparam shadowing false

actor Administrador
participant "AulasListView\n(React)" as UI <<Component>>
participant "useAulas\n(Hook)" as Hook <<Hook>>
participant "AulasService\n(Axios)" as FService <<Service>>
participant "AulasController\n(NestJS)" as Controller <<Controller>>
participant "AulasService\n(NestJS)" as BService <<Service>>
database "PostgreSQL" as DB

Administrador -> UI : Click en eliminar aula

== Verificación de impacto ==

UI -> Hook : verificarImpacto(id)
Hook -> FService : verificarImpacto(id)
FService -> Controller : GET /aulas/:id/impacto
Controller -> BService : countDependencies(id)

BService -> DB : SELECT COUNT(*)...
DB --> BService : totalExamenes

BService --> Controller : totalExamenes
Controller --> FService : 200 OK (totalExamenes)
FService --> Hook : totalExamenes
Hook --> UI : totalExamenes
UI --> Administrador : Mostrar confirmación(totalExamenes)

Administrador -> UI : Confirma eliminación

== Ejecución ==

UI -> Hook : deleteAula(id)
Hook -> FService : deleteAula(id)
FService -> Controller : DELETE /aulas/:id
Controller -> BService : remove(id)

BService -> DB : DELETE FROM "Aula" WHERE id = :id
DB --> BService : OK

BService --> Controller : OK (204 No Content)
Controller --> FService : OK
FService --> Hook : OK
Hook --> UI : Quita aula de la lista local
UI --> Administrador : Muestra mensaje de éxito

@enduml