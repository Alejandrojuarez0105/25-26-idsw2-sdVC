@startuml secuencia-diseño
skinparam shadowing false

actor Administrador
participant "AulaEditView\n(React)" as UI <<Component>>
participant "useAulaEditForm\n(Hook)" as Hook <<Hook>>
participant "AulasService\n(Axios)" as FService <<Service>>
participant "AulasController\n(NestJS)" as Controller <<Controller>>
participant "AulasService\n(NestJS)" as BService <<Service>>
database "PostgreSQL" as DB

== Carga de Datos ==

Administrador -> UI : Accede a editar aula
UI -> Hook : loadAula(id)
Hook -> FService : getAulaById(id)
FService -> Controller : GET /aulas/:id
Controller -> BService : findOne(id)
BService -> DB : SELECT * FROM "Aula" WHERE id = :id
DB --> BService : Aula Data
BService --> Controller : Aula Entity
Controller --> FService : JSON Response
FService --> Hook : Aula Object
Hook --> UI : Rellena formulario

== Edición ==

Administrador -> UI : Modifica campos
Administrador -> UI : Click en "Guardar"
UI -> Hook : update(id, data)
Hook -> FService : updateAula(id, data)
FService -> Controller : PUT /aulas/:id (JSON Body)
Controller -> BService : update(id, dto)
BService -> DB : UPDATE "Aula" SET ... WHERE id = :id
DB --> BService : OK
BService --> Controller : Updated Aula Entity
Controller --> FService : JSON Response
FService --> Hook : Success
Hook --> UI : Redirigir / Mostrar éxito
UI --> Administrador : Muestra confirmación de cambios

@enduml