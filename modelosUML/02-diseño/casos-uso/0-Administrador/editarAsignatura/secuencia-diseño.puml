@startuml secuencia-diseño
skinparam shadowing false

actor Administrador
participant "AsignaturaEditForm\n(React)" as UI <<Component>>
participant "useAsignaturas\n(Hook)" as Hook <<Hook>>
participant "AsignaturasService\n(Axios)" as FService <<Service>>
participant "AsignaturasController\n(NestJS)" as Controller <<Controller>>
participant "AsignaturasService\n(NestJS)" as BService <<Service>>
database "PostgreSQL" as DB

== Carga de Datos ==
Administrador -> UI : Accede a editar asignatura
UI -> Hook : getAsignatura(id)
Hook -> FService : findOne(id)
FService -> Controller : GET /asignaturas/:id
Controller -> BService : findOne(id)
BService -> DB : SELECT * FROM "Asignatura" WHERE id = :id
DB --> BService : Asignatura Data
BService --> Controller : Asignatura Entity
Controller --> FService : JSON Response
FService --> Hook : Asignatura Object
Hook --> UI : Rellena formulario

== Edición ==
Administrador -> UI : Modifica datos y pulsa "Guardar"
UI -> Hook : update(id, data)
Hook -> FService : updateAsignatura(id, data) 
FService -> Controller : PUT /asignaturas/:id (JSON Body)
Controller -> BService : update(id, dto)
BService -> DB : UPDATE "Asignatura" SET ... WHERE id = :id
DB --> BService : Asignatura actualizada
BService --> Controller : Updated Asignatura Entity
Controller --> FService : JSON Response (200 OK)
FService --> Hook : Success
Hook --> UI : Redirigir / Mostrar éxito
UI --> Administrador : Muestra mensaje de éxito
@enduml
