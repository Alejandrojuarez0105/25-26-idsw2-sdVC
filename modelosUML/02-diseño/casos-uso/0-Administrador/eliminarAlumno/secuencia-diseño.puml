@startuml secuencia-diseño
skinparam shadowing false

actor Administrador
participant "EliminarAlumnoView\n(React)" as UI <<Component>>
participant "useAlumnoDelete\n(Hook)" as Hook <<Hook>>
participant "AlumnosService\n(Axios)" as FService <<Service>>
participant "AlumnosController\n(NestJS)" as Controller <<Controller>>
participant "AlumnosService\n(NestJS)" as BService <<Service>>
database "PostgreSQL" as DB

== Confirmación de eliminación ==

Administrador -> UI : Selecciona alumno a eliminar
Administrador -> UI : Click en "Eliminar"
UI -> UI : Muestra confirmación
Administrador -> UI : Confirma eliminación

== Ejecución ==

UI -> Hook : removeAlumno(id)
Hook -> FService : deleteAlumno(id)
FService -> Controller : DELETE /alumnos/:id
Controller -> BService : remove(id)

BService -> DB : DELETE FROM alumno WHERE id = :id
DB --> BService : OK

BService --> Controller : OK
Controller --> FService : JSON Response (200 OK)
FService --> Hook : Success
Hook --> UI : Actualiza lista / Redirige
UI --> Administrador : Muestra confirmación de borrado

@enduml