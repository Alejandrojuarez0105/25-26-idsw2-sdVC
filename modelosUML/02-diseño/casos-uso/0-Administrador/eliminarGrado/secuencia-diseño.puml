@startuml secuencia-diseño
skinparam shadowing false

actor Administrador
participant "GradosListView\n(React)" as UI <<Component>>
participant "useGrados\n(Hook)" as Hook <<Hook>>
participant "GradosService\n(Axios)" as FService <<Service>>
participant "GradosController\n(NestJS)" as Controller <<Controller>>
participant "GradosService\n(Logic)" as BService <<Service>>
database "PostgreSQL" as DB

Administrador -> UI : Click en eliminar grado

== Verificación de impacto ==

UI -> Hook : verificarImpacto(id)
Hook -> FService : verificarImpacto(id)
FService -> Controller : GET /grados/:id/impacto
Controller -> BService : countDependencies(id)
BService -> DB : SELECT COUNT(*) ...
DB --> BService : totalAsignaturas
BService --> Controller : totalAsignaturas
Controller --> FService : 200 OK (totalAsignaturas)
FService --> Hook : totalAsignaturas
Hook --> UI : totalAsignaturas
UI --> Administrador : Mostrar confirmación(totalAsignaturas)

Administrador -> UI : Confirma eliminación

== Ejecución ==

UI -> Hook : deleteGrado(id)
Hook -> FService : deleteGrado(id)
FService -> Controller : DELETE /grados/:id
Controller -> BService : remove(id)
BService -> DB : DELETE FROM "Grado" WHERE id = :id
DB --> BService : OK
BService --> Controller : OK (204 No Content)
Controller --> FService : OK
FService --> Hook : OK
Hook --> UI : Quita grado de la lista local
UI --> Administrador : Muestra mensaje de éxito

@enduml