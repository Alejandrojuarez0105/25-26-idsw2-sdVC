@startuml secuencia-diseño
skinparam shadowing false

actor Administrador
participant "EditarAlumnoView\n(React)" as UI <<Component>>
participant "useAlumnoForm\n(Hook)" as Hook <<Hook>>
participant "AlumnosService\n(Axios)" as FService <<Service>>
participant "AlumnosController\n(NestJS)" as Controller <<Controller>>
participant "AlumnosService\n(NestJS)" as BService <<Service>>
database "PostgreSQL" as DB

== Carga de Datos ==

Administrador -> UI : Accede a editar alumno
UI -> Hook : loadAlumno(id)
Hook -> FService : getAlumnoById(id)
FService -> Controller : GET /alumnos/:id
Controller -> BService : findOne(id)
BService -> DB : SELECT * FROM "Alumno" WHERE id = :id
DB --> BService : Alumno Data
BService --> Controller : Alumno Entity
Controller --> FService : JSON Response
FService --> Hook : Alumno Object
Hook --> UI : Rellena formulario

== Edición ==

Administrador -> UI : Modifica campos
Administrador -> UI : Click en "Guardar"
UI -> Hook : update(id, data)
Hook -> FService : updateAlumno(id, data)
FService -> Controller : PUT /alumnos/:id (JSON Body)
Controller -> BService : update(id, dto)
BService -> DB : UPDATE alumno SET ... WHERE id = :id
DB --> BService : OK
BService --> Controller : Alumno Entity
Controller --> FService : JSON Response
FService --> Hook : Success
Hook --> UI : Redirigir / Mostrar éxito
UI --> Administrador : Muestra confirmación

@enduml