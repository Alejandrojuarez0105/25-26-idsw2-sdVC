@startuml secuencia-diseño
skinparam shadowing false

actor Administrador
participant "ImportAulasView\n(React)" as UI <<Component>>
participant "useAulasImport\n(Hook)" as Hook <<Hook>>
participant "AulasService\n(Axios)" as FService <<Service>>
participant "AulasController\n(NestJS)" as Controller <<Controller>>
participant "AulasService\n(NestJS)" as BService <<Service>>
database "PostgreSQL" as DB

Administrador -> UI : Selecciona archivo (CSV/Excel)
Administrador -> UI : Click en "Importar"

UI -> Hook : importAulas(file)
Hook -> FService : importAulas(file)
FService -> Controller : POST /aulas/import (Multipart/Form-Data)

Controller -> BService : processImport(fileBuffer)

loop Por cada fila del archivo
    BService -> BService : Validar datos

    alt Datos válidos
        BService -> DB : UPSERT "Aula"
    else Datos inválidos
        BService -> BService : Registrar error
    end
end

BService --> Controller : ImportResultDTO
Controller --> FService : JSON Response (201 Created)
FService --> Hook : ImportResultDTO
Hook --> UI : Actualiza estado (resultados)

UI --> Administrador : Muestra resumen de importación

@enduml