@startuml secuencia-diseño-descargarCalendarioExamenes-profesor
skinparam shadowing false
skinparam responseMessageBelowArrow true

actor Profesor
participant "ConsultarCalendarioView\n(React)" as UI <<Component>>
participant "DescargarCalendarioModal\n(React)" as Modal <<Component>>
participant "examenesService\n(Axios)" as FService <<Service>>
participant "ExamenesController\n(NestJS)" as Controller <<Controller>>
participant "RolesGuard / JWT" as Guard <<Guard>>
participant "ExportacionService\n(NestJS)" as Export <<Service>>
participant "ExamenExporterFactory" as Factory <<Factory>>
participant "ExamenExporter\n(Excel | PDF)" as Strategy <<Strategy>>
participant "ExamenesService\n(NestJS)" as BService <<Service>>
participant "PrismaService" as Prisma <<ORM>>
database "PostgreSQL 16" as DB

Profesor -> UI : descargarCalendarioExamenes()
UI -> Modal : abrir (formato + opciones)
Profesor -> Modal : elige formato (pdf|excel) y columnas
Modal -> FService : descargarCalendario(filtros, formato, opciones)
FService -> Controller : GET /examenes/exportar?formato&incluirAula&...\n(Authorization: Bearer JWT)

Controller -> Guard : validar token + rol
Guard --> Controller : req.user { profesorId, rol = Profesor }
Controller -> Export : exportar(filtros, formato, opciones, usuario)
Export -> BService : findCalendario(filtros, usuario)
BService -> BService : forzar where.profesorId = usuario.profesorId
BService -> Prisma : examen.findMany({ where: { profesorId }, include: aula })
Prisma -> DB : SELECT exámenes del profesor + aula
DB --> Prisma : Exámenes propios
Prisma --> BService : Lista de exámenes
BService --> Export : ExamenExportData[] (inmutable)

Export -> Factory : crear(formato)
Factory --> Export : ExamenExporter concreto
Export -> Strategy : exportar(datos, opciones)
Strategy --> Export : Buffer (binario)

Export --> Controller : Buffer + metadatos
Controller --> FService : 200 OK\nContent-Disposition: attachment\n(calendario.pdf | calendario.xlsx)
FService --> Modal : Blob
Modal -> Modal : crear URL + <a> virtual -> click
Modal --> Profesor : Archivo descargado
Modal --> UI : cerrar -> regresa a CALENDARIO_ABIERTO

@enduml
