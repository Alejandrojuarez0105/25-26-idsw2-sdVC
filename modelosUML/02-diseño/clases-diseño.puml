@startuml clases-diseño-davidario

title Diagrama de Clases de Diseño - Davidario - Iteración 1

package "Dominio / Modelos" {

    class Universidad {
        + id: UUID
        + nombre: string
    }

    class Facultad {
        + id: UUID
        + nombre: string
        + universidadId: UUID
    }

    class Grado {
        + id: UUID
        + nombre: string
        + facultadId: UUID
    }

    class Asignatura {
        + id: UUID
        + codigo: string
        + nombre: string
        + creditos: number
        + gradoId: UUID
    }

    class Profesor {
        + id: UUID
        + codigo: string
        + nombre: string
        + apellidos: string
        + email: string
        + departamento: string
    }

    class Alumno {
        + id: UUID
        + expediente: string
        + nombre: string
        + apellidos: string
        + email: string
    }

    class Aula {
        + id: UUID
        + codigo: string
        + nombre: string
        + capacidad: number
        + edificio: string
        + planta: string
        + tipo: string
    }

    class Examen {
        + id: UUID
        + fecha: Date
        + asignaturaId: UUID
        + aulaId: UUID
        + supervisorId: UUID
        + estado: ExamenEstado
    }

    enum ExamenEstado {
        PENDIENTE
        PROGRAMADO
        FINALIZADO
        CANCELADO
    }

    class FranjaHoraria {
        + id: UUID
        + dia: DayOfWeek
        + horaInicio: Time
        + horaFin: Time
    }
}

package "API / Schemas (DTOs)" {

    class CreateExamenDTO {
        + asignaturaId: UUID
        + fecha: Date
    }

    class UpdateExamenDTO {
        + aulaId: UUID
        + supervisorId: UUID
        + fecha: Date
    }
}

package "Relaciones de Dominio" {

    Universidad "1" *-- "*" Facultad
    Facultad "1" *-- "*" Grado
    Grado "1" *-- "*" Asignatura

    Asignatura "*" o-- "*" Profesor : "impartida por"
    Asignatura "1" o-- "*" Alumno : "inscritos en"
    Asignatura "1" o-- "*" Examen : "evalúa mediante"

    Examen "1" --> "0..1" Aula : "se realiza en"
    Examen "1" --> "0..1" Profesor : "supervisado por"
    Examen "*" --> "0..1" FranjaHoraria : "programado en"
    Examen "*" o-- "*" Alumno : "presentado por"
}

@enduml